# =============================================================================
# LOCAL DEVELOPMENT ONLY
# =============================================================================
# Copy this file to .env and edit for your machine:
#   cp .env.example .env
#
# This file is NOT used on Railway. Never commit a real .env file.
# =============================================================================

# Your local PostgreSQL (adjust user/db for your setup)
# macOS Homebrew example: postgresql://YOUR_MAC_USERNAME@localhost:5432/team_task_manager
DATABASE_URL="postgresql://YOUR_USER@localhost:5432/team_task_manager"

JWT_SECRET="local-dev-secret-change-me"
PORT=3001
NODE_ENV=development

# Vite dev server URL (only needed for local CORS)
CLIENT_URL="http://localhost:5173"

# =============================================================================
# PRODUCTION (Railway) — do NOT copy the values above
# =============================================================================
# Set these on your Railway WEB service (or use railway.toml in repo root):
#
#   DATABASE_URL     → ${{Postgres.DATABASE_URL}}  (auto via railway.toml)
#   NODE_ENV         → production                  (auto via railway.toml)
#   JWT_SECRET       → openssl rand -hex 32        (YOU must set in Railway UI)
#   PORT             → (Railway sets automatically)
#   CLIENT_URL       → optional; auto from RAILWAY_PUBLIC_DOMAIN
#
# See RAILWAY_SETUP.md in the project root for full deploy steps.
